# ===== LLM API Key（必填）=====
# 阿里云 DashScope API Key，从 https://dashscope.console.aliyun.com/apiKey 获取
DASHSCOPE_API_KEY=sk-your-api-key-here

# ===== 鉴权 =====
# 生产环境务必设置；留空则跳过鉴权（开发模式）
API_TOKEN=

# ===== 环境模式 =====
# dev / prod — 加载 config/<env>.py 中的配置
APP_ENV=dev
# 0 = 本地开发（localhost）, 1 = Docker 容器内
DOCKER_ENV=0

# ===== LLM 配置 =====
# 阿里云 DashScope 可用模型：
#   deepseek-v3   — DeepSeek-V3（推荐）
#   qwen-turbo    — 最快最省（免费额度 200万 token/月）
#   qwen-plus     — 平衡性价比（免费额度 100万 token/月）
#   qwen-max      — 最强，复杂任务
LLM_MODEL=deepseek-v3
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
TOP_K=3

# ===== Agent =====
MAX_CHAT_HISTORY=20

# ===== CORS =====
# 多个域名用逗号分隔，* 表示允许所有
CORS_ORIGINS=*

# ===== 限流（每分钟请求数）=====
RATELIMIT_CHAT=100
RATELIMIT_STREAM=30
RATELIMIT_GENERAL=200

# ===== 数据库连接池 =====
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ===== PostgreSQL 会话库 =====
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=change-me-in-production
PG_DBNAME=ai_customer

# ===== PostgreSQL 向量库（pgvector）=====
VECTOR_PG_HOST=localhost
VECTOR_PG_PORT=5433
VECTOR_PG_USER=postgres
VECTOR_PG_PASSWORD=change-me-in-production
VECTOR_PG_DBNAME=ai_customer

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6379/0

# ===== 业务微服务内部地址 =====
INNER_ORDER_API=http://business_api:8001
INNER_CRM_API=http://business_api:8001/api/crm

# ===== MySQL（业务数据库）=====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me-in-production
MYSQL_DATABASE=business_db

# ===== LangFuse 可观测性（可选）=====
# 从 https://cloud.langfuse.com 获取
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
